# PayPi-Bridge Environment Variables
# Copy this file to .env and fill in the values

# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
DB_NAME=paypibridge
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Pi Network Integration
PI_API_KEY=your-pi-api-key-here
PI_WALLET_PRIVATE_SEED=your-pi-wallet-private-seed-here
PI_NETWORK=Pi Testnet

# CCIP/Relayer Webhook
CCIP_WEBHOOK_SECRET=your-ccip-webhook-secret-here
CCIP_WEBHOOK_ALLOWED_IPS=127.0.0.1,::1

# Open Finance / Open Banking
OF_BASE_URL=https://api.openbanking.sandbox.example.com
OF_CLIENT_ID=your-open-finance-client-id
OF_CLIENT_SECRET=your-open-finance-client-secret
# OF_USE_MOCK=true (default) — use false para tentar cliente OF real (requer OF_BASE_URL e credenciais)

# Pix via OpenPix (Woovi) — liquidação real/sandbox (transferência entre chaves)
# Documentação: https://developers.openpix.com.br/docs/apis/getting-started-api
# Transfer: POST /api/v1/transfer — value (centavos), fromPixKey (sua conta), toPixKey (destino)
PIX_PROVIDER=
# openpix — ativa envio via API OpenPix (ignora mock OF enquanto configurado)
OPENPIX_APP_ID=
# AppID copiado do painel API/Plugins (header Authorization)
OPENPIX_APP_SECRET=
# Reservado; a API REST documentada usa só AppID no Authorization
OPENPIX_FROM_PIX_KEY=
# Chave Pix de origem cadastrada na conta OpenPix (mesma titularidade/conta de liquidação)
OPENPIX_BASE_URL=https://api.openpix.com.br/api/v1
OPENPIX_TIMEOUT=30

# FX Service
FX_API_KEY=your-fx-api-key-here
FX_BASE_URL=https://api.exchangerate-api.com/v4/latest

# Security
KYC_PROVIDER_API_KEY=your-kyc-provider-api-key
PII_VAULT_ENCRYPTION_KEY=your-encryption-key-32-chars-minimum

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
