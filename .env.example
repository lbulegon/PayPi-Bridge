# === Core ===
DJANGO_SECRET=change-me
ENV=dev

# === Database ===
# Opção 1: DATABASE_URL (recomendado para Railway, Heroku, etc.)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Opção 2: Variáveis individuais (para desenvolvimento local)
# Desenvolvimento local (sem Docker): localhost
DB_HOST=localhost
DB_PORT=5432
DB_NAME=paypibridge
DB_USER=postgres
DB_PASSWORD=postgres

# === Pi Network (obrigatório para saldo e verificação de pagamento) ===
# Obter em: https://develop.pi → criar app → API Key + Wallet (seed começando com S, 56 caracteres)
PI_API_KEY=
PI_WALLET_PRIVATE_SEED=
# Rede: "Pi Testnet" (sandbox) ou "Pi Network" (mainnet)
PI_NETWORK=Pi Testnet

# Horizon (opcional): cruzar txid no ledger. Use o URL do Horizon que indexa o ledger Pi alvo
# (horizon-testnet.stellar.org é Stellar público, NÃO é Pi mainnet).
ENABLE_LEDGER_VERIFICATION=false
HORIZON_URL=
LEDGER_VERIFY_TIMEOUT=10
# Se true, exige que o valor da operação "payment" no Horizon coincida com amount_pi do intent
STRICT_LEDGER_AMOUNT_MATCH=false

# Liquidação automática (Pi → BRL → Pix): taxa sobre o bruto em BRL (ex: 0.05 = 5%). Default 0.
SETTLEMENT_FEE_RATE=0

# === Open Finance / Pix (sandbox ou mock) ===
# Deixe OF_BASE_URL vazio ou OF_USE_MOCK=true para usar mock (sem provedor real).
# Mock: POST /api/consents e POST /api/payouts/pix retornam sucesso sem chamar API externa.
OF_USE_MOCK=true
OF_BASE_URL=
OF_CLIENT_ID=
OF_CLIENT_SECRET=
# mTLS (opcional; sandbox pode exigir)
OF_MTLS_CERT_PATH=
OF_MTLS_KEY_PATH=
OF_CA_CERT_PATH=
# Identificador da organização (alguns provedores)
OF_ORG_ID=

# === CCIP / Webhooks ===
CCIP_WEBHOOK_SECRET=replace-with-random-hmac
CCIP_RELAYER_WHITELIST=1.2.3.4,5.6.7.8

# === KYC/AML Provider ===
KYC_API_KEY=...

# === Celery / Redis (liquidação assíncrona) ===
# Com Redis a correr na máquina (ex.: redis-server em 127.0.0.1:6379)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# Resultados no Postgres (opcional): CELERY_RESULT_BACKEND=django-db + migrate django_celery_results
# SETTLEMENT_ASYNC=0 — executa liquidação na mesma request (sem fila)
SETTLEMENT_ASYNC=1
# Forçar execução síncrona de tasks (útil sem worker); testes usam eager automático
# CELERY_TASK_ALWAYS_EAGER=1
CELERY_TASK_ACKS_LATE=1
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# === Observability ===
SENTRY_DSN=...

# === PPBridge Service ===
# API Security
PPBRIDGE_API_KEY_ENABLED=false  # true para habilitar autenticação por API Key
PPBRIDGE_API_KEY=change_me

# Webhooks
PPBRIDGE_WEBHOOK_HMAC_SECRET=change_me_webhook_secret
PPBRIDGE_WEBHOOK_TIMEOUT_SECONDS=5
PPBRIDGE_WEBHOOK_MAX_RETRIES=3

# Logging
PPBRIDGE_LOG_LEVEL=INFO
